   "id": "b5cfb563",
   "metadata": {},
   "outputs": [],
   "source": [
    "matriz = [\n",
    "    [10, 5, 100],\n",
    "    [20, 5, 200],\n",
    "    [30, 2, 300]\n",
    "]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "4f3876e5",
   "metadata": {},
   "outputs": [],
   "source": [
    "#somar o valor 10 a todos os elemntos dessa matriz\n",
    "for linha in matriz:\n",
    "    for i in range(len(linha)):\n",
    "        linha[i] +=10\n",
    "        "
   ]
  },
  {
